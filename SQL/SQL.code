-- =========================================
-- RETAIL ETL PIPELINE PROJECT
-- =========================================

DROP DATABASE IF EXISTS Retail_ETL;
CREATE DATABASE Retail_ETL;
USE Retail_ETL;

-- =========================================
-- STAGING TABLE
-- =========================================

CREATE TABLE stg_orders (
    order_id INT,
    customer_name VARCHAR(100),
    city VARCHAR(50),
    product_name VARCHAR(100),
    category VARCHAR(50),
    quantity INT,
    unit_price DECIMAL(10,2),
    order_date DATE
);

