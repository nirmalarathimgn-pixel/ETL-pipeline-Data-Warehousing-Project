-- =========================================
-- DIMENSION TABLES
-- =========================================

CREATE TABLE dim_customer (
    customer_key INT AUTO_INCREMENT PRIMARY KEY,
    customer_name VARCHAR(100),
    city VARCHAR(50)
);

CREATE TABLE dim_product (
    product_key INT AUTO_INCREMENT PRIMARY KEY,
    product_name VARCHAR(100),
    category VARCHAR(50)
);

CREATE TABLE dim_date (
    date_key INT PRIMARY KEY,
    order_date DATE,
    year INT,
    month INT,
    quarter_no INT
);

-- =========================================
-- FACT TABLE
-- =========================================

CREATE TABLE fact_sales (
    sales_key INT AUTO_INCREMENT PRIMARY KEY,
    customer_key INT,
    product_key INT,
    date_key INT,
    quantity INT,
    sales_amount DECIMAL(12,2),

    FOREIGN KEY (customer_key)
    REFERENCES dim_customer(customer_key),

    FOREIGN KEY (product_key)
    REFERENCES dim_product(product_key),

    FOREIGN KEY (date_key)
    REFERENCES dim_date(date_key)
);

-- =========================================
-- ETL STEP 1
-- CUSTOMER DIMENSION LOAD
-- =========================================

INSERT INTO dim_customer(customer_name, city)
SELECT DISTINCT customer_name, city
FROM stg_orders;

-- =========================================
-- ETL STEP 2
-- PRODUCT DIMENSION LOAD
-- =========================================

INSERT INTO dim_product(product_name, category)
SELECT DISTINCT product_name, category
FROM stg_orders;

-- =========================================
-- ETL STEP 3
-- DATE DIMENSION LOAD
-- =========================================

INSERT INTO dim_date
SELECT DISTINCT
       YEAR(order_date)*10000 +
       MONTH(order_date)*100 +
       DAY(order_date) AS date_key,
       order_date,
       YEAR(order_date),
       MONTH(order_date),
       QUARTER(order_date)
FROM stg_orders;

-- =========================================
-- ETL STEP 4
-- FACT TABLE LOAD
-- =========================================

INSERT INTO fact_sales
(
customer_key,
product_key,
date_key,
quantity,
sales_amount
)
SELECT
c.customer_key,
p.product_key,
d.date_key,
s.quantity,
s.quantity * s.unit_price
FROM stg_orders s

JOIN dim_customer c
ON s.customer_name = c.customer_name
AND s.city = c.city

JOIN dim_product p
ON s.product_name = p.product_name
AND s.category = p.category

JOIN dim_date d
ON s.order_date = d.order_date;

-- =========================================
-- ANALYSIS QUERIES
-- =========================================

-- 1. VIEW FACT TABLE

SELECT * FROM fact_sales;

-- 2. MONTHLY REVENUE

SELECT
d.year,
d.month,
SUM(f.sales_amount) AS revenue
FROM fact_sales f
JOIN dim_date d
ON f.date_key = d.date_key
GROUP BY d.year,d.month
ORDER BY d.year,d.month;

-- 3. TOP PRODUCTS

SELECT
p.product_name,
SUM(f.sales_amount) AS revenue
FROM fact_sales f
JOIN dim_product p
ON f.product_key = p.product_key
GROUP BY p.product_name
ORDER BY revenue DESC;

-- 4. TOP CUSTOMERS

SELECT
c.customer_name,
SUM(f.sales_amount) AS revenue
FROM fact_sales f
JOIN dim_customer c
ON f.customer_key = c.customer_key
GROUP BY c.customer_name
ORDER BY revenue DESC;

-- 5. SALES BY CATEGORY

SELECT
p.category,
SUM(f.sales_amount) AS revenue
FROM fact_sales f
JOIN dim_product p
ON f.product_key = p.product_key
GROUP BY p.category
ORDER BY revenue DESC;

-- 6. CITY WISE SALES

SELECT
c.city,
SUM(f.sales_amount) AS revenue
FROM fact_sales f
JOIN dim_customer c
ON f.customer_key = c.customer_key
GROUP BY c.city
ORDER BY revenue DESC;
